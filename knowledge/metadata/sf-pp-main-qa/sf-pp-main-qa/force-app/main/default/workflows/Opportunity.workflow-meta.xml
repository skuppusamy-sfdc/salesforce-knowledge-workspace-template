&quot;EM Sales Opportunity&quot;, Total_Revenue__c/4200000, 
&quot;UC Sales Opportunity&quot;, Total_Revenue__c/4200000, 
&quot;ICP Sales Opportunity&quot;, Total_Revenue__c/4200000, 
&quot;HM Sales Opportunity&quot;, Total_Revenue__c/1530000, 
&quot;TELE Sales Opportunity&quot;, Total_Revenue__c/1530000, 
&quot;ICU Sales Opportunity&quot;, Total_Revenue__c/1530000, 
null)</formula>
        <name>CE by Rev 2017</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
