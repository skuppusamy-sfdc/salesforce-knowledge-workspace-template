<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>Update_Account_Owner</fullName>
        <field>OwnerId</field>
        <lookupValue>systemintegration@sg.bd</lookupValue>
        <lookupValueType>User</lookupValueType>
        <name>Update Account Owner</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>LookupValue</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Update_ED_Volume_with_DHC</fullName>
        <field>ED_Volume__c</field>
        <formula>TOTAL_ER_VISITS__c</formula>
        <name>Update ED Volume with DHC</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Account - Update Outreach Account Record Type</fullName>
        <active>false</active>
        <description>Updates the Outreach Record Type field when the Account Record Type field changes</description>
        <formula>Outreach_Record_Type__c  &lt;&gt;  RecordType.Name</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Update ED Volume</fullName>
        <actions>
            <name>Update_ED_Volume_with_DHC</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Account.ED_Volume__c</field>
            <operation>equals</operation>
        </criteriaItems>
        <description>Updates ED Volume When Null</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>WF_Set Default Account Owner</fullName>
        <actions>
            <name>Update_Account_Owner</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Account.Was_a_Lead_Discovery__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <description>This workflow rule will set Account Owner to Jamie Hidalgo, if the account was created from Lead Conversion Process.</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
</Workflow>
