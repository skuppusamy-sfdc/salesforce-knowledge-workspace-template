<?xml version="1.0" encoding="UTF-8"?>
<LightningMessageChannel xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Lightning Message Channel used to log a Webex call</description>
    <isExposed>false</isExposed>
    <lightningMessageFields>
        <description>This is the ID of the called contact or lead</description>
        <fieldName>whoId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>This is the type of the logged call</description>
        <fieldName>type</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>This is the ID of the related record</description>
        <fieldName>whatId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>This is the called phone number</description>
        <fieldName>phone</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>This is the called email</description>
        <fieldName>email</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>This is the called duration</description>
        <fieldName>duration</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>This is the called direction</description>
        <fieldName>direction</fieldName>
    </lightningMessageFields>
    <masterLabel>WebexCallLogChannel</masterLabel>
</LightningMessageChannel>
