        <apex:outputPanel id="scripts">
            <script>

                ChangeUserTabView();

                let idTimeOut;
                (() => {
                    let selecId = document.getElementById('{!$Component.integrationSelectList}');
                    let presentationItems = Array.from(document.querySelectorAll(`li[role="presentation"]`));
                    let tabAnchors = Array.from(document.querySelectorAll(`.slds-tabs_default__link`));
                    let tabPanels = Array.from(document.querySelectorAll(`.slds-tabs_default__content`));
                    let CollectorBlock = document.getElementById('CollectorBlock');

                    selecId.value === 'true' ? CollectorBlock.style.display = 'block' : CollectorBlock.style.display = 'none';

                    let currentTabAnchor = tabAnchors.find(i => {
                        return i.tabIndex == 0;
                    });
                    let currentPresentation = presentationItems.find(i => {
                        return i.classList.contains('slds-active');
                    });

                    let currentTabPanel = tabPanels.find(i => {
                        return i.classList.contains('slds-show');
                    });

                    tabAnchors.forEach(element => {

                        element.addEventListener('click', event => {
                            if (element.tabIndex === 0) {
                                return;
                            }

                            currentPresentation.classList.remove('slds-active');
                            currentTabPanel.classList.remove('slds-show');
                            currentTabPanel.classList.add('slds-hide');
                            currentTabAnchor.setAttribute('tabindex', -1);
                            currentTabAnchor.setAttribute('aria-selected', false);

                            element.parentElement.classList.add('slds-active');
                            element.setAttribute('tabindex', 0);
                            element.setAttribute('aria-selected', true);
                            let result = tabPanels.find(i => {
                                return i.getAttribute('id') == element.getAttribute('aria-controls');
                            });
                            result.classList.add('slds-show');
                            result.classList.remove('slds-hide');

                            currentTabPanel = result;
                            currentTabAnchor = element;
                            currentPresentation = element.parentElement;


                            UpdateBlockForProductTrigger();

                        })
                    });
                })();

                function updateFieldValuesInCustomSetting(Id, fieldName, isChecked) {

                    showAllCheckboxOnProductTrigger();

                    if(Id.split('.')[0] ==='Product2')
                    {
                        updateProductTriggerFieldValuesWithProduct(fieldName,isChecked);
                    }
                    else if(Id.split('.')[0] ==='Opportunity')
                    {
                        updateProductTriggerFieldValuesWithOpportunity(fieldName,isChecked);

                    }



                }





                function changeProductsVisible() {


                    let productsSelect = document.getElementById('{!$Component.productsSelect}');
                    let productsRow = Array.from(document.querySelectorAll('#productsRow'));
                    let opportunityRow = Array.from(document.querySelectorAll('#opportunityRow'));
                    let allProductSelectCb = document.getElementById('AllProductCheckBox');
                    let allOppSelectCb = document.getElementById('AllOppCheckBox');


                    if (productsSelect.value === 'Opportunity') {
                        productsRow.forEach(element => {
                            element.style.display = 'none';
                        });
                        opportunityRow.forEach(element => {
                            element.style.display = '';
                        });
                        allOppSelectCb.style.display = 'block';
                        allProductSelectCb.style.display = 'none';

                    } else {
                        productsRow.forEach(element => {
                            element.style.display = '';
                        });
                        opportunityRow.forEach(element => {
                            element.style.display = 'none';
                        });
                        allOppSelectCb.style.display = 'none';
                        allProductSelectCb.style.display = 'block';
                    }
                }



                changeProductsVisible();




                function selectedAllProfilesFieldValues() {

                    console.log('selectedAllProfilesFieldValues');


                    let allSelectedCheckBox = document.getElementById('all-profiles-field-map');

                    if(allSelectedCheckBox.checked)
                    {
                        Array.from(document.querySelectorAll('.profileCheckBox')).forEach(checkbox=>{
                            checkbox.checked = true;
                        });
                    }else {
                        Array.from(document.querySelectorAll('.profileCheckBox')).forEach(checkbox=>{
                            checkbox.checked = false;
                        });
                    }

                    updateProfileFieldValuesInCustomSetting();

                }




                function selectedAllUsersFieldValues() {

                    console.log('selectedAllUsersFieldValues');


                    let allSelectedCheckBox = document.getElementById('all-users-field-map');


                    if(allSelectedCheckBox.checked)
                    {
                        Array.from(document.querySelectorAll('.userFieldMap')).forEach(checkbox=>{

                            checkbox.checked = true;
                            checkbox.value = 'true';

                        });
                    }else {
                        Array.from(document.querySelectorAll('.userFieldMap')).forEach(checkbox=>{
                            checkbox.checked = false;
                            checkbox.value = 'false';
                        });
                    }

                }







                function selectedAllRolesFieldValues() {

                    console.log('selectedAllRolesFieldValues');


                    let allSelectedCheckBox = document.getElementById('all-roles-field-map');

                    if(allSelectedCheckBox.checked)
                    {
                       Array.from(document.querySelectorAll('.roleCheckBox')).forEach(checkbox=>{
                            checkbox.checked = true;
                        });
                    }else {
                        Array.from(document.querySelectorAll('.roleCheckBox')).forEach(checkbox=>{
                            checkbox.checked = false;
                        });
                    }

                    updateRolesFieldValuesInCustomSetting();

                }


                function changeTabVisible() {
                    let selecId = document.getElementById('{!$Component.integrationSelectList}');


                    let presentationItems = Array.from(document.querySelectorAll(`li[role="presentation"]`));
                    presentationItems.forEach(tab => {
                        let tittle = tab.getAttribute('title');
                        tab.style.display = 'block';

                        if (selecId.value === 'false')
                        {
                            if (tittle !== 'Integration' && tittle !== 'Users' && tittle !== 'Triggers' && tittle!=="ProductTriggers" && tittle !== 'ProductDefinition')  // && tittle !=='Email'
                            {
                                tab.style.display = 'none';
                            }
                        } else {
                            tab.style.display = 'block';
                            if(tittle ==="ProductTriggers")
                            {
                                tab.style.display = 'none';
                            }
                        }
                    });

                    let CollectorBlock = document.getElementById('CollectorBlock');
                    selecId.value === 'true' ? CollectorBlock.style.display = 'block' : CollectorBlock.style.display = 'none';


                    let productFamilyHelpTruSales = document.getElementById('product-family-help--truSales');
                    let productFamilyHelpTruVoice = document.getElementById('product-family-help--truVoice');

                    if(selecId.value === 'false')
                    {

                        productFamilyHelpTruSales.style.display = 'block';
                        productFamilyHelpTruVoice.style.display = 'none';

                    }
                    else
                    {

                        productFamilyHelpTruSales.style.display = 'none';
                        productFamilyHelpTruVoice.style.display = 'block';

                    }

                    clearProductFields();
                    clearOpportunityFields();

                }

                function SelectUsersView() {
