                function updateStatefulButtonsCounter(name) {
                    const enabled = Array.from(document.querySelectorAll(`*[aria-pressed="true"][data-name="${name}"]`)).length;
                    const disabled = Array.from(document.querySelectorAll(`*[aria-pressed="false"][data-name="${name}"]`)).length;

                    document.querySelector(`.${name}.counter .enabled`).innerHTML = enabled.toString();
                    document.querySelector(`.${name}.counter .disabled`).innerHTML = disabled.toString();
                }
