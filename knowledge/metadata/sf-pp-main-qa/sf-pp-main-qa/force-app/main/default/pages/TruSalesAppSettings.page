                function getTruVoiceProducts() {
                    //TODO REMOVE THIS!!!
                    //const programId = '58af4da0b310d92314627232';
                    const programId = '{!settings.Initiative_id__c}';
                    const xhr = new XMLHttpRequest();
                    xhr.open('GET', '{!settings.API_EndPoint__c}/sfa/clients/{!settings.TruVoice_Client_ID__c}/initiatives/' + programId + '/products', true);
                    console.log('{!settings.API_EndPoint__c}/sfa/clients/{!settings.TruVoice_Client_ID__c}/initiatives/' + programId + '/products');
                    xhr.setRequestHeader('apikey', '{!settings.TruVoice_API_Key__c}');
                    xhr.setRequestHeader('x-truvoice-client', '{!settings.TruVoice_Client_ID__c}');

                    xhr.onreadystatechange = () => {
                        if (xhr.readyState === 4) {
                            const products = JSON.parse(xhr.responseText);
                            console.log(xhr.responseText);

                            const productsSelectOptions = [];
                            productsSelectOptions.push({name: 'Exclude', label: 'Exclude'});

                            products.map(product => {
                                productsSelectOptions.push({
                                    name: product.id,
                                    label: product.name
                                });
                            });
                            setTruVoiceProducts(JSON.stringify(productsSelectOptions));
                        }
                    };
                    xhr.send();
                }


