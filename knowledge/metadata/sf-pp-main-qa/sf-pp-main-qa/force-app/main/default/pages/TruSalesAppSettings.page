                function attachStatefulButtonsClickEvent() {
                    // Logic for stateful buttons groups
                    Array.from(document.querySelectorAll('.stateful-buttons-container')).map(container => {
                        container.onclick = null;

                        container.addEventListener('click', event => {
                            const target = event.target;

                            if (target.tagName !== 'BUTTON')
                                return;

                            const isRadio = (target.getAttribute('data-type') || '').toLowerCase() === 'radio';

                            if (target.getAttribute('aria-pressed') === 'false') {
                                target.setAttribute('aria-pressed', 'true');
                                target.classList.remove('slds-button_neutral');
                                target.classList.add('slds-button_success');
                            } else {
                                target.setAttribute('aria-pressed', 'false');
                                target.classList.add('slds-button_neutral');
                                target.classList.remove('slds-button_success');
                            }

                            if (isRadio) {
                                target.setAttribute('restriction', 'restricted');
                                Array.from(document.querySelectorAll(`*[aria-pressed="true"][data-name="${target.getAttribute('data-name')}"]:not([restriction])`)).map(button => {
                                    button.setAttribute('aria-pressed', 'false');
                                    button.classList.add('slds-button_neutral');
                                    button.classList.remove('slds-button_success');
                                });
                                target.removeAttribute('restriction');
                            }

                            let total = '';
                            Array.from(document.querySelectorAll(`*[aria-pressed="true"][data-name="${target.getAttribute('data-name')}"]`)).map(button => {
                                total += button.getAttribute('data-id');
                            });
                            document.querySelector(`*[id$="${target.getAttribute('data-name')}"]`).value = total;

                            updateStatefulButtonsCounter(target.getAttribute('data-name'));
                        });
                    });
                }

