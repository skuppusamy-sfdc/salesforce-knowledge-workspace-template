        <script>

            function updateUsersCheckBoxes() {

                console.log('updateUsersCheckBoxes');

                let allUserCb = document.getElementById('all-users-field-map');
                let allUserInput = Array.from(document.querySelectorAll('.userFieldMap'));

                let UserInp = allUserInput.filter(checkbox=>{
                    return checkbox.checked === true;
                });


                if(UserInp.length > 0 && allUserInput.length != UserInp.length)
                {
                    if (allUserCb.readOnly)
                    {
                        allUserCb.checked = allUserCb.readOnly = false;
                    }
                    else
                    {
                        allUserCb.readOnly = allUserCb.indeterminate = true;
                    }

                }
                else if(UserInp.length == 0)
                {
                    allUserCb.checked = false;
                    allUserCb.indeterminate = false;
                    allUserCb.readOnly = false;
                }
                else if(UserInp.length > 0 && allUserInput.length == UserInp.length)
                {

                    allUserCb.checked = true;
                    allUserCb.indeterminate = false;
                    allUserCb.readOnly = false;
                }


            }




            function updateProfileFieldValuesInCustomSetting() {

                console.log('updateProfileFieldValuesInCustomSetting');

                let allProfileCb = document.getElementById('all-profiles-field-map');
                let allProfileInput = Array.from(document.querySelectorAll('.profileCheckBox'));


                allProfileInput.forEach(input => {
                    if (input.getAttribute('data-is-selected') == 'true') {
                        input.checked = true;
                        input.setAttribute('data-is-selected','false');
                    }
                });

                let profileInp = allProfileInput.filter(checkbox=>{
                    return checkbox.checked === true;
                });


                if(profileInp.length > 0 && allProfileInput.length != profileInp.length)
                {
                    if (allProfileCb.readOnly)
                    {
                        allProfileCb.checked = allProfileCb.readOnly = false;
                    }
                    else
                    {
                        allProfileCb.readOnly = allProfileCb.indeterminate = true;
                    }

                }
                else if(profileInp.length == 0)
                {
                    allProfileCb.checked = false;
                    allProfileCb.indeterminate = false;
                    allProfileCb.readOnly = false;
                }
                else if(profileInp.length > 0 && allProfileInput.length == profileInp.length)
                {
                    allProfileCb.checked = true;
                    allProfileCb.indeterminate = false;
                    allProfileCb.readOnly = false;
                }


                let resultStr = '';
                let ObjArray = new Array();

                profileInp.forEach(item=>{
                    let objResponse = {
                        'Id' : item.dataset.profileId,
                        'label' : item.dataset.profileLabel
                    };

                    ObjArray.push(objResponse);
                });


                resultStr = JSON.stringify(ObjArray);

                let profileInpHidden = document.getElementById('{!$Component.profileInpHidden}');
                profileInpHidden.value = resultStr;

            }




            function updateRolesFieldValuesInCustomSetting() {

                console.log('updateRolesFieldValuesInCustomSetting');



                let allRoleCb = document.getElementById('all-roles-field-map');
                let allRoleInput = Array.from(document.querySelectorAll('.roleCheckBox'));

                allRoleInput.forEach(input => {
                    if (input.getAttribute('data-is-selected') == 'true') {
                        input.checked = true;
                        input.setAttribute('data-is-selected','false');
                    }
                });


                let roleInp = allRoleInput.filter(checkbox=>{
                    return (checkbox.checked === true);
                });


                if(roleInp.length > 0 && allRoleInput.length != roleInp.length)
                {
                    if (allRoleCb.readOnly)
                    {
                        allRoleCb.checked = allRoleCb.readOnly = false;
                    }
                    else
                    {
                        allRoleCb.readOnly = allRoleCb.indeterminate = true;
                    }

                }
                else if(roleInp.length == 0)
                {
                    allRoleCb.checked = false;
                    allRoleCb.indeterminate = false;
                    allRoleCb.readOnly = false;
                }
                else if(roleInp.length > 0 && allRoleInput.length == roleInp.length)
                {
                    allRoleCb.checked = true;
                    allRoleCb.indeterminate = false;
                    allRoleCb.readOnly = false;
                }




                let resultStr = '';
                let ObjArray = new Array();

                roleInp.forEach(item=>{
                    let objResponse = {
                        'Id' : item.dataset.roleId,
                        'label' : item.dataset.roleLabel
                    };

                    ObjArray.push(objResponse);
                });


                resultStr = JSON.stringify(ObjArray);

                let roleInpHidden = document.getElementById('{!$Component.rolesInpHidden}');
                roleInpHidden.value = resultStr;

            }


            function showAllCheckboxOnProductTrigger() {

                console.log('showAllCheckboxOnProductTrigger');

                let allSelectedCheckbox = document.getElementById('all-productTrigger-field-map');


                let allProductTriggerCheckboxesFirst = Array.from(document.querySelectorAll('.productTriggerFirst'));
                let allProductTriggerCheckboxesSecond = Array.from(document.querySelectorAll('.productTriggerSecond'));
                allProductTriggerCheckboxesFirst.push(...allProductTriggerCheckboxesSecond);

                let productTriggerCheckbox = allProductTriggerCheckboxesFirst.filter(checkbox=>{
                    return checkbox.checked === true;
                });


                if(productTriggerCheckbox.length > 0 && allProductTriggerCheckboxesFirst.length != productTriggerCheckbox.length)
                {
                    if (allSelectedCheckbox.readOnly)
                    {
                        allSelectedCheckbox.checked = allSelectedCheckbox.readOnly = false;
                    }
                    else
                    {
                        allSelectedCheckbox.readOnly = allSelectedCheckbox.indeterminate = true;
                    }

                }
                else if(productTriggerCheckbox.length == 0)
                {
                    allSelectedCheckbox.checked = false;
                    allSelectedCheckbox.indeterminate = false;
                    allSelectedCheckbox.readOnly = false;
                }
                else if(productTriggerCheckbox.length > 0 && allProductTriggerCheckboxesFirst.length == productTriggerCheckbox.length)
                {

                    allSelectedCheckbox.checked = true;
                    allSelectedCheckbox.indeterminate = false;
                    allSelectedCheckbox.readOnly = false;
                }

            }

            function showOpoOwner() {
