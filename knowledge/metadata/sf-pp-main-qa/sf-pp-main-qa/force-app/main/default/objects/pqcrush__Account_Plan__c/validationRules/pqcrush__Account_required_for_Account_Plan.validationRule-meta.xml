<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>pqcrush__Account_required_for_Account_Plan</fullName>
    <active>true</active>
    <description>If the Record Type is Account Plan, then the Account lookup is required.</description>
    <errorConditionFormula>AND(
   RecordType.DeveloperName = &apos;Account_Plan&apos;,
   ISBLANK( pqcrush__Account__c )
)</errorConditionFormula>
    <errorDisplayField>pqcrush__Account__c</errorDisplayField>
    <errorMessage>Account field is required.</errorMessage>
</ValidationRule>
