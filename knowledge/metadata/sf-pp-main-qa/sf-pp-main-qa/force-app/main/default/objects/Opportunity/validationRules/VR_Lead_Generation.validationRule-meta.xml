<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR_Lead_Generation</fullName>
    <active>false</active>
    <description>Value field must be between 0% and 25%</description>
    <errorConditionFormula>Lead_Generation__c &lt; 0 ||  Lead_Generation__c &gt; (25/100)</errorConditionFormula>
    <errorDisplayField>Lead_Generation__c</errorDisplayField>
    <errorMessage>value must be between 0% and 25%</errorMessage>
</ValidationRule>
