<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Only_Sister_Site_can_have_ServiceAccount</fullName>
    <active>true</active>
    <errorConditionFormula>(Account.RecordType.DeveloperName = &quot;Corporate_Entity&quot; &amp;&amp; PartyRoleRelation.Name = &quot;Sister-Sister-AAR&quot;) ||(
(Account.RecordType.DeveloperName &lt;&gt; &quot;Corporate_Entity&quot;) &amp;&amp;
(Account.RecordType.DeveloperName = &quot;Service_Account&quot; &amp;&amp; PartyRoleRelation.Name &lt;&gt; &quot;Sister-Sister-AAR&quot;))</errorConditionFormula>
    <errorDisplayField>AccountId</errorDisplayField>
    <errorMessage>Only &quot;Sister-Sister-AAR&quot; PartyRoleRelation can have service account, rest should be Corporate Entity</errorMessage>
</ValidationRule>
