<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Declined_Reason</fullName>
    <active>true</active>
    <errorConditionFormula>AND (ISPICKVAL( bpats__Applicant_Status__c, &quot;Rejected&quot;),
ISBLANK (TEXT(Declined_Detail__c)))</errorConditionFormula>
    <errorDisplayField>Declined_Detail__c</errorDisplayField>
    <errorMessage>The Declined Reason and Declined Detail must be filled out on the Applicant record</errorMessage>
</ValidationRule>
