<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Provide_Other_Detail</fullName>
    <active>false</active>
    <description>Force the user to provide other reason when the field Close Reason value is Other</description>
    <errorConditionFormula>AND(
 ISPICKVAL(Close_Reason__c,&quot;Other&quot;),
  Other_Detail__c == &quot;&quot; 
)</errorConditionFormula>
    <errorDisplayField>Other_Detail__c</errorDisplayField>
    <errorMessage>Please provide Other Reason Code.</errorMessage>
</ValidationRule>
