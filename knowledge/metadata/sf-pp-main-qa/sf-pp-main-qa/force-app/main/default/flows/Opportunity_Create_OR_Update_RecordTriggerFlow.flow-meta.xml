                <elementReference>$User.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_lstTaskRecords</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_TaskRecord</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_ServiceAccounts</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>Check “Green Light for Client Outreach” to Checked/True</description>
        <name>If_Green_Light_for_Client_Outreach_Checkbox_True</name>
        <label>If Green Light for Client Outreach Checkbox True</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Green_Light_for_Client_Outreach_Checkbox_True</name>
            <conditionLogic>1 AND (2 OR 5) AND (3 OR 4 OR 6)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Growth_Opportunity</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Green_Light_for_Client_Outreach__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Green_Light_for_Client_Outreach__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>fr_ISNew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.LOI_Complete__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.LOI_Complete__c</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Task_for_Opportunity</targetReference>
            </connector>
            <label>Green Light for Client Outreach Checkbox True</label>
        </rules>
    </decisions>
    <decisions>
        <description>Check var_lstServiceAccountIds is not emapty. These service account IDs do not have a VPO user assigned to them in the Account Team Members.</description>
        <name>If_Service_Account_Id_Present</name>
        <label>If Service Account Id Present</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>If_Task_Records_Present</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Service_Account_Id_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_lstServiceAccountIds</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Service_Account</targetReference>
            </connector>
            <label>Service Account Id Present</label>
        </rules>
    </decisions>
    <decisions>
        <name>If_Task_Records_Present</name>
        <label>If Task Records Present</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Task_Records_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_lstTaskRecords</leftValueReference>
                <operator>IsEmpty</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Task_Records</targetReference>
            </connector>
            <label>Task Records Present</label>
        </rules>
    </decisions>
    <decisions>
        <name>If_VP_Operation_User_Present</name>
        <label>If VP Operation User Present</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_ATM</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>VP_Operation_User_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_ATM.TeamMemberRole</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>VP Operations</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Task_Record1</targetReference>
            </connector>
            <label>VP Operation User Present</label>
        </rules>
    </decisions>
    <description>Created As part of US-PR1050558-2139</description>
    <environments>Default</environments>
    <formulas>
        <name>fr_ISNew</name>
        <dataType>Boolean</dataType>
        <expression>ISNEW()</expression>
    </formulas>
    <formulas>
        <name>fr_TaskDueDate</name>
        <dataType>Date</dataType>
        <expression>ADDMONTHS(TODAY(), 0) + 3</expression>
