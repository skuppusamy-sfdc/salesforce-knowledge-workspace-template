<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_Global_Id</name>
        <label>Assign Global Id</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>globalProviderId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Fr_GlobalIdNumber</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>GetEmploymentType</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>AssignAdditionalAttributes</name>
        <label>AssignAdditionalAttributes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>EmploymentType</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>GetEmploymentType.Employment_Type__c</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <description>check null name</description>
        <name>nameNullorNot</name>
        <label>nameNullorNot</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>bothIdandname</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>globalId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>clinicianName</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>searchByBoth</targetReference>
            </connector>
            <label>bothIdandName</label>
        </rules>
        <rules>
            <name>Name</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>clinicianName</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>searchByName</targetReference>
            </connector>
            <label>Name</label>
        </rules>
        <rules>
            <name>Global</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>globalId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>searchByID</targetReference>
            </connector>
            <label>GlobalIDvalue</label>
        </rules>
    </decisions>
    <description>This flow validates the clinician based on the global Id entered.</description>
    <environments>Default</environments>
    <formulas>
        <name>Fr_GlobalIdNumber</name>
        <dataType>Number</dataType>
        <expression>VALUE({!GlobalIdText})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>Fr_GlobalIdText</name>
        <dataType>String</dataType>
        <expression>TEXT({!globalId})</expression>
    </formulas>
    <interviewLabel>validateClinicianUsingGlobalId {!$Flow.CurrentDateTime}</interviewLabel>
    <label>validateClinicianUsingGlobalId</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
