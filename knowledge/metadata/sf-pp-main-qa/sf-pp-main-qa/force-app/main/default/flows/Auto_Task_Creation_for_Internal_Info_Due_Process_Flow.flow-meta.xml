    <description>This Flow runs when I update the Opportunity (RT: Opportunity Growth) field “Client Questionnaire Status” = Info Due Process Ready
Then the system will check that ALL of the following Opportunity fields are already populated or not.</description>
    <environments>Default</environments>
    <interviewLabel>Auto Task Creation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Auto Task Creation for Internal Info Due Process Flow</label>
    <loops>
        <name>Loop_on_active_services</name>
        <label>Loop on active services</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Related_Services_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Add_Service_Account_Id_In_Array</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Service_Account_using_IDs</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_on_Deal_Team_Member</name>
        <label>Loop on Deal Team Member</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_All_Deal_Team_Member</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Create_List_of_Role_Name</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Check_Recruitment_Manager_Role_Exists</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_on_Service_Accounts</name>
        <label>Loop on Service Accounts</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Service_Account_using_IDs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Check_Service_Line_Parent</targetReference>
        </nextValueConnector>
    </loops>
