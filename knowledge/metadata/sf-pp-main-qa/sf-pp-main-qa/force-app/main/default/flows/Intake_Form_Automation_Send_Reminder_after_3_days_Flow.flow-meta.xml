    <decisions>
        <name>Check_Professional_Title_On_Contact</name>
        <label>Check Professional Title On Contact</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Title_NP_PA_RN</name>
            <conditionLogic>(1 OR 2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Professional_Title__pc</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>NP</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Professional_Title__pc</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PA</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Professional_Title__pc</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>RN</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Recipient</leftValueReference>
                <operator>NotEqualTo</operator>
            </conditions>
            <connector>
                <targetReference>Send_Email_to_NP_PA_Clinician</targetReference>
            </connector>
            <label>Title NP/PA/RN</label>
        </rules>
        <rules>
            <name>Title_MD_DO</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Account.Professional_Title__pc</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MD</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Account.Professional_Title__pc</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DO</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Recipient</leftValueReference>
                <operator>NotEqualTo</operator>
            </conditions>
            <connector>
                <targetReference>Send_Email_to_MD_DO_Clinician</targetReference>
            </connector>
            <label>Title MD/DO</label>
        </rules>
    </decisions>
