    <decisions>
        <name>Insurance_Check</name>
        <label>Insurance Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Last_Contracted_Date</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Check_HPF_Insurance</name>
            <conditionLogic>1 AND (2 OR 3) AND 4 AND ((5 AND 6) OR 7)</conditionLogic>
            <conditions>
                <leftValueReference>Set_HPF_Last_Contracted_Date.Insurance_Provided_By__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Set_HPF_Last_Contracted_Date.Certificate_of_Insurance_Expiration__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Set_HPF_Last_Contracted_Date.Certificate_of_Insurance_Expiration__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$System.OriginDateTime</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Set_HPF_Last_Contracted_Date.Credentialling_Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Active</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$System.OriginDateTime</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Set_HPF_Last_Contracted_Date.EffectiveFrom</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$System.OriginDateTime</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>Set_HPF_Last_Contracted_Date.EffectiveTo</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Set_HPF_Last_Contracted_Date.EffectiveTo</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_HPF_Last_Contracted_Date</targetReference>
            </connector>
            <label>Check HPF Insurance</label>
        </rules>
    </decisions>
