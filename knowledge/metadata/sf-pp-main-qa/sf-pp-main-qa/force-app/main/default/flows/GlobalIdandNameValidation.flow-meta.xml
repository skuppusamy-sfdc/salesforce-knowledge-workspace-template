<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>AddToAccountList</name>
        <label>AddToAccountList</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>AccountIdList</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>LoopOnHPFs.AccountId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>LoopOnHPFs</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>AssignOutput</name>
        <label>AssignOutput</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>GlobalFacilityIds</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>LoopByServiceLine</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>LoopByServiceLine</targetReference>
        </connector>
    </assignments>
    <decisions>
        <description>check null name</description>
        <name>nameNullorNot</name>
        <label>nameNullorNot</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Global</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>globalId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>getAccountRecordUsingGlobalId</targetReference>
            </connector>
            <label>GlobalIDvalue</label>
        </rules>
    </decisions>
    <description>Validate clinical using Global ID or Name</description>
    <environments>Default</environments>
    <formulas>
        <name>Fr_GlobalIdText</name>
        <dataType>String</dataType>
        <expression>TEXT({!globalId})</expression>
    </formulas>
    <interviewLabel>GlobalIdandNameValidation {!$Flow.CurrentDateTime}</interviewLabel>
    <label>GlobalIdandNameValidation</label>
    <loops>
        <name>LoopByServiceLine</name>
        <label>LoopByServiceLine</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>GetServiceLineInfo</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>AssignOutput</targetReference>
        </nextValueConnector>
    </loops>
    <loops>
        <name>LoopOnHPFs</name>
        <label>LoopOnHPFs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_HPF_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>AddToAccountList</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>GetServiceLineInfo</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_HPF_Records</name>
        <label>Get HPF Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>LoopOnHPFs</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>PractitionerId</field>
            <operator>In</operator>
            <value>
                <elementReference>StoreOnlyIds</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Active</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <limit>
            <numberValue>30.0</numberValue>
        </limit>
        <object>HealthcarePractitionerFacility</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>AccountId</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <description>pull the account details using the globalId</description>
        <name>getAccountRecordUsingGlobalId</name>
        <label>getAccountRecordUsingGlobalId</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>StoreOnlyIds</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Global_Provider_ID__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Fr_GlobalIdText</elementReference>
            </value>
        </filters>
        <object>Contact</object>
        <outputReference>MatchedClinicianRecords</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>Global_Provider_ID__c</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>GetServiceLineInfo</name>
        <label>GetServiceLineInfo</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>LoopByServiceLine</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>In</operator>
            <value>
                <elementReference>AccountIdList</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <limit>
            <numberValue>50.0</numberValue>
        </limit>
        <object>Account</object>
        <queriedFields>Id</queriedFields>
        <queriedFields>Global_Facility_ID__c</queriedFields>
        <queriedFields>Name</queriedFields>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>nameNullorNot</targetReference>
        </connector>
    </start>
    <status>Active</status>
    <transforms>
        <name>StoreOnlyIds</name>
        <label>StoreOnlyIds</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_HPF_Records</targetReference>
        </connector>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <scale>0</scale>
        <storeOutputAutomatically>true</storeOutputAutomatically>
        <transformValues>
            <transformValueActions>
                <transformType>Map</transformType>
                <value>
                    <elementReference>MatchedClinicianRecords[$EachItem].Id</elementReference>
                </value>
            </transformValueActions>
        </transformValues>
    </transforms>
    <variables>
        <name>AccountIdList</name>
        <dataType>String</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>this will contain clinicianName</description>
        <name>clinicianName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>FaultErrorMessage</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <description>Output global facility Ids where clinician works</description>
        <name>GlobalFacilityIds</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>true</isOutput>
        <objectType>Account</objectType>
    </variables>
    <variables>
        <description>takes the global Id as input</description>
        <name>globalId</name>
        <dataType>Number</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
        <scale>0</scale>
    </variables>
    <variables>
        <name>MatchedClinicianRecords</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Contact</objectType>
    </variables>
</Flow>
