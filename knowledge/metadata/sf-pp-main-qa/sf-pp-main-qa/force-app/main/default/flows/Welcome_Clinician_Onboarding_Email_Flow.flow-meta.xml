        UPPER(TRIM(TEXT({!Get_Latest_HPF_Record.Practitioner.Professional_Title__c}))) = &quot;PA&quot;,
        UPPER(TRIM(TEXT({!Get_Latest_HPF_Record.Practitioner.Professional_Title__c}))) = &quot;RN&quot;,
        UPPER(TRIM(TEXT({!Get_Latest_HPF_Record.Practitioner.Professional_Title__c}))) = &quot;LPN&quot;
    ),
    {!Get_Latest_HPF_Record.Practitioner.FirstName},
    IF(
        OR(
            UPPER(TRIM(TEXT({!Get_Latest_HPF_Record.Practitioner.Professional_Title__c}))) = &quot;MD&quot;,
            UPPER(TRIM(TEXT({!Get_Latest_HPF_Record.Practitioner.Professional_Title__c}))) = &quot;DO&quot;
        ),
        &quot;Dr.&quot;+&apos; &apos;+{!Get_Latest_HPF_Record.Practitioner.LastName},
