<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_Author_and_Date</name>
        <label>Set Author and Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.AuthorName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>AuthorName</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.AuthoredDateTime</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>frmAuthoredDate</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <environments>Default</environments>
    <formulas>
        <name>AuthorName</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.AuthorName}),{!$User.FirstName} + &apos; &apos; + {!$User.LastName}, {!$Record.AuthorName})</expression>
    </formulas>
    <formulas>
        <name>frmAuthoredDate</name>
        <dataType>DateTime</dataType>
        <expression>IF(ISBLANK({!$Record.AuthoredDateTime}), NOW(), {!$Record.AuthoredDateTime})</expression>
    </formulas>
    <interviewLabel>Author Note Before Save {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Author Note Before Save</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Author_and_Date</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>AuthorName</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>AuthoredDateTime</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>AuthorNote</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
