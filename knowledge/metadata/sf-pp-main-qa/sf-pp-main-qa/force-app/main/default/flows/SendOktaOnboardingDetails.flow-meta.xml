        <locationY>0</locationY>
        <assignNextValueToReference>currentItem_Filter_User_FedID</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>GET_User</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Filter_User_FedID.AccountId</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <elementReference>Loop_on_Contracts.AccountId</elementReference>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Loop_on_Filtered_User</targetReference>
        </connector>
    </collectionProcessors>
    <constants>
        <description>Awaiting response from Mule team on blank or “NULL”</description>
        <name>FedIdBlank</name>
        <dataType>String</dataType>
        <value>
            <stringValue>null</stringValue>
        </value>
    </constants>
    <environments>Default</environments>
    <formulas>
        <name>for_SSNLast4Digit</name>
        <dataType>String</dataType>
        <expression>&quot;1234&quot;</expression>
    </formulas>
    <formulas>
        <name>GlobalProviderId</name>
        <dataType>String</dataType>
        <expression>({!Loop_on_Contracts.Account.Global_Provider_ID__pc})</expression>
    </formulas>
    <formulas>
        <name>MobilePhone</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE({!Loop_on_Contracts.Account.PersonMobilePhone},&apos;-&apos;,&apos;&apos;)</expression>
    </formulas>
    <interviewLabel>Send Okta Onboarding Details {!$Flow.CurrentDateTime}</interviewLabel>
