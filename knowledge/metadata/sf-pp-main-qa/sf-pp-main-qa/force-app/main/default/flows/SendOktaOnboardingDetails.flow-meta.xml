            <value>
                <elementReference>Loop_on_Filtered_User.FederationIdentifier</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_on_Filtered_User</targetReference>
        </connector>
    </assignments>
    <collectionProcessors>
        <name>Filter_User_FedID</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Filter User FedID</label>
