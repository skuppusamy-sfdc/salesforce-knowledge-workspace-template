    <recordLookups>
        <name>Get_Client_Contract_PNC_Records</name>
        <label>Get Client Contract PNC Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Client_Contracting_Queue</targetReference>
        </connector>
        <filterLogic>or</filterLogic>
        <filters>
            <field>Contract_Termination__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>todaysDate</elementReference>
            </value>
        </filters>
        <filters>
            <field>Contract_Termination__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>NextDay</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>ProviderNetworkContract</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Client_Contracting_Queue</name>
        <label>Get Client Contracting Queue</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Offboarding_Case_RecordTypeId</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Type</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Queue</stringValue>
            </value>
        </filters>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Client_Contracting_Queue</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Group</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
