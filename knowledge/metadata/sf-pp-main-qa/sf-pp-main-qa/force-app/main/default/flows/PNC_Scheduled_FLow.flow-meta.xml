    </decisions>
    <decisions>
        <name>Check_If_tasks_to_be_created</name>
        <label>Check If tasks to be created?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_not_null</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>TaskList</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_Client_Termination_Tasks</targetReference>
            </connector>
            <label>Is not null?</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_termination_date</name>
        <label>Check termination date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Loop_on_PNCs</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>today</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_on_PNCs.Contract_Termination__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>todaysDate</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Related_HPF_Records</targetReference>
            </connector>
            <label>today?</label>
        </rules>
        <rules>
            <name>tomorrow</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_on_PNCs.Contract_Termination__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>NextDay</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_on_PNCs.Contract.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Executed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Service_Account_Name</targetReference>
            </connector>
            <label>tomorrow?</label>
        </rules>
    </decisions>
    <description>This flow runs daily and create offboarding cases for PNC records where termination date is today</description>
    <environments>Default</environments>
    <formulas>
        <name>CaseSubject</name>
        <dataType>String</dataType>
        <expression>&apos;Facility Offboarding-&apos; + {!facilityName}</expression>
    </formulas>
    <formulas>
        <name>NextDay</name>
        <dataType>Date</dataType>
        <expression>TODAY()+1</expression>
    </formulas>
    <formulas>
        <name>TaskSubject</name>
        <dataType>String</dataType>
        <expression>{!serviceAccountName} + &apos; Client Contract Terminated&apos;</expression>
    </formulas>
    <formulas>
        <name>todaysDate</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>PNC Scheduled FLow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>PNC Scheduled FLow</label>
    <loops>
        <name>Loop_on_Hpfs</name>
        <label>Loop on Hpfs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Related_HPF_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Get_Existing_Facility_Offboarding_Case</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Loop_on_PNCs</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Loop_on_PNCs</name>
        <label>Loop on PNCs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_Client_Contract_PNC_Records</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Check_Contract_Type</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Check_if_records_to_be_created</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
