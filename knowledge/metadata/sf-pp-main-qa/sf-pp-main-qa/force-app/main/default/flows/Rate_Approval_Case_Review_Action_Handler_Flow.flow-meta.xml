    <textTemplates>
        <name>tt_ApprovalBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;{!Get_User.FirstName} has requested your approval for the following Rate Approval Case&amp;nbsp;&lt;a href=&quot;{!fr_RecordLink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!fr_RecordLink}&lt;/a&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Thank you,&amp;nbsp;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!Get_User.FirstName} {!Get_User.LastName}&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_Body</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;{!fr_Subject}&lt;/p&gt;&lt;p&gt;Please check the following comments:&lt;/p&gt;&lt;p&gt;{!var_Comment}&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>tt_CommentIndividual</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Reviewed By : {!Iterate_Over_AWE.ReviewedBy.FirstName}  {!Iterate_Over_AWE.ReviewedBy.LastName} &lt;/p&gt;&lt;p&gt;Reviewed Date : {!fr_ReviewedDate}&lt;/p&gt;&lt;p&gt;Comments : {!Iterate_Over_AWE.Comments}&lt;/p&gt;</text>
    </textTemplates>
