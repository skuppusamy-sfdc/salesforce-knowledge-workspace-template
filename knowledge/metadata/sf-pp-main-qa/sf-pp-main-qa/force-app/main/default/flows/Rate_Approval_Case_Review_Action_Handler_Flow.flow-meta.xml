    <description>PR1050558-2469 - Creating this flow to handle the background steps of Rate Approval Case Approval Process Flow</description>
    <environments>Default</environments>
    <formulas>
        <name>fr_AccountTeamRole</name>
        <dataType>String</dataType>
        <expression>IF( ({!GET_Case.APAY_Used_for_the_Month__c} + {!fr_BonusAmount}) &gt; {!GET_Case.APAY_Budgeted__c} , &quot;Division Operating Officer&quot;, &quot;VP Operations&quot;)</expression>
    </formulas>
    <formulas>
        <name>fr_BonusAmount</name>
        <dataType>Currency</dataType>
        <expression>IF(  ISPICKVAL({!GET_Case.Bonus_Unit_of_Measure__c}, &quot;per Hour&quot;) , {!GET_Case.Shift_Compensation__c}, {!GET_Case.Bonus_Amount__c})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>fr_RecordLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_260}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_260})) &amp; {!var_CaseId}</expression>
    </formulas>
    <formulas>
        <name>fr_ReviewedDate</name>
        <dataType>Date</dataType>
        <expression>DATEVALUE({!Iterate_Over_AWE.ReviewedDate})</expression>
    </formulas>
    <formulas>
        <name>fr_Subject</name>
        <dataType>String</dataType>
        <expression>IF({!var_CaseStatus} == &quot;Approved&quot; ,{!var_CaseNumber} &amp; &quot; Rate Approval Case is Approved&quot;, {!var_CaseNumber} &amp; &quot; Rate Approval Case is Rejected&quot;)</expression>
    </formulas>
    <interviewLabel>Rate Approval Case Review Action Handler Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Rate Approval Case Review Action Handler Flow</label>
    <loops>
