    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_for_Status</targetReference>
        </connector>
        <object>HealthcarePractitionerFacility</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>HPF_Save_Sub_Flow</name>
        <label>HPF Save Sub Flow</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Assign_HPF_record_to_List</targetReference>
        </connector>
        <flowName>HPF_Save_Sub_Flow</flowName>
        <inputAssignments>
            <name>NewHPF</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputAssignments>
        <outputAssignments>
            <assignToReference>HPFListToUpdate</assignToReference>
            <name>NewHPF</name>
        </outputAssignments>
    </subflows>
    <subflows>
