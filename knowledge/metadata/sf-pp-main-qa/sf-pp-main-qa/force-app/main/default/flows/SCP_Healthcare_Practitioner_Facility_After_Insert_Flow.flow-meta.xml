        </connector>
        <flowName>Update_Active_HPF_to_Inactive</flowName>
        <inputAssignments>
            <name>employmentType</name>
            <value>
                <elementReference>$Record.Employment_Type__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>practitionerId</name>
            <value>
                <elementReference>$Record.PractitionerId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>recordId</name>
