<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Assign_HPF_record_to_List</name>
        <label>Assign HPF record to List</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>HPFListToUpdateCollection</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>HPFListToUpdate</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Update_HPF_Record</targetReference>
        </connector>
    </assignments>
    <decisions>
        <name>Check_for_Status</name>
        <label>Check for Status</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>HPF_Save_Sub_Flow</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>is_Active</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Active</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Inactivate_Existing_HPF</targetReference>
            </connector>
            <label>is Active</label>
        </rules>
    </decisions>
    <description>- PR1050558-473 : Create Healthcare Provider Record when Healthcare Practitioner Facility Record is created.</description>
    <environments>Default</environments>
    <interviewLabel>Healthcare Practitioner Facility After Insert Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Healthcare Practitioner Facility After Insert Flow</label>
    <processMetadataValues>
