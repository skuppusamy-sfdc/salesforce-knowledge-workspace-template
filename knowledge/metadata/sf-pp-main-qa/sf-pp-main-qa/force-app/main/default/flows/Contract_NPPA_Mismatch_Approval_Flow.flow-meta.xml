<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <constants>
        <description>Stores the value for the status of a step that&apos;s been approved. The value of the constant must be Approve.</description>
        <name>Approved</name>
        <dataType>String</dataType>
        <value>
            <stringValue>Approve</stringValue>
        </value>
    </constants>
    <decisions>
        <name>NPPA_Mismatch_Approval_Flow</name>
        <label>NPPA Mismatch Approval Flow</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>If_there_is_a_mismatch</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Clinician</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.WaitingForApproval_NPPA_Tier__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Submitted</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Regional_Director_Approval</targetReference>
            </connector>
            <label>If there is a mismatch</label>
        </rules>
    </decisions>
    <description>PR1050558-2235 : Approval Flow Runs for NPPA Mismatch Approval</description>
    <environments>Default</environments>
    <formulas>
        <name>formulaFinalNPPATier</name>
        <dataType>String</dataType>
        <expression>TEXT({!$Record.WaitingForApproval_NPPA_Tier__c})</expression>
    </formulas>
    <interviewLabel>Contract NPPA Mismatch Approval Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Contract NPPA Mismatch Approval Flow</label>
    <orchestratedStages>
        <name>Regional_Director_Approval</name>
