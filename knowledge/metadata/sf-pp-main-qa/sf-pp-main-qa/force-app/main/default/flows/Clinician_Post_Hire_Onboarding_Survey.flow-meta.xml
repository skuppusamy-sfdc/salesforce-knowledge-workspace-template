    <description>This flow creates case, sends email and creates onboarding form for clinician post hire onboarding survey</description>
    <environments>Default</environments>
    <formulas>
        <name>assessmentExpirationDate</name>
        <dataType>DateTime</dataType>
        <expression>NOW() + 30</expression>
    </formulas>
    <formulas>
        <name>caseOwner</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!Get_CES_from_Account_team.User.Id})),{!Get_CES_from_Account_team.User.Id},{!$User.Id})</expression>
    </formulas>
    <formulas>
        <name>emailTitle</name>
        <dataType>String</dataType>
        <expression>{!hpfRecord.Practitioner.FirstName} + &quot; &quot; +  {!hpfRecord.Practitioner.MiddleName} + &quot; &quot; + {!hpfRecord.Practitioner.LastName} + &quot;, &quot; + TEXT({!hpfRecord.Practitioner.Professional_Title__c})</expression>
    </formulas>
    <formulas>
        <name>siteId</name>
        <dataType>String</dataType>
        <expression>LEFT({!Get_Core_Connect_Site.Id}, 15)</expression>
    </formulas>
    <interviewLabel>Clinician Post Hire Onboarding Survey {!$Flow.CurrentDateTime}</interviewLabel>
