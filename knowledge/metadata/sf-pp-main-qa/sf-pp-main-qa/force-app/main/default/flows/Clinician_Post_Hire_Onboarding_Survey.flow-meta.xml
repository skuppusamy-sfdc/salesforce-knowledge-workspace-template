    <status>Active</status>
    <textTemplates>
        <name>emailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Dear {!emailTitle},&lt;/p&gt;&lt;p&gt;Welcome again to SCP Health! We’re grateful you’ve joined our team and we want to make sure your onboarding experience was as smooth and supportive as possible.&lt;/p&gt;&lt;p&gt;To help us continue improving, would you take &lt;strong&gt;3 minutes&lt;/strong&gt; to share your feedback in this short survey?&lt;/p&gt;&lt;p&gt;Your input will help us refine the process so future clinicians enjoy the same whiteglove experience we aim to provide.&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;{!Get_Site_Details.SecureUrl}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;Clinician Onboarding Experience Survey&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Thank you for your time — and for the care you bring to your patients. We’re glad you’re here.&lt;/p&gt;&lt;p&gt;Warm regards,&lt;/p&gt;&lt;p&gt;{!Create_case.Owner:User.FirstName} {!Create_case.Owner:User.LastName}&lt;/p&gt;&lt;p&gt;Clinician Experience Team&lt;/p&gt;</text>
    </textTemplates>
