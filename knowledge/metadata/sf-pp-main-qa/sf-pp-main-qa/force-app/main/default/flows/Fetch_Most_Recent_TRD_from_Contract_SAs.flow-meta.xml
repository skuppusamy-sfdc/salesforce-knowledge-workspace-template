    <decisions>
        <name>Fetch_Regional_Director_of_NPPA</name>
        <label>Fetch Regional Director of NPPA</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>If_Operation_is_Fetch_RD</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varOperation</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>FetchRegionalDirector</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_All_PNC_Records</targetReference>
            </connector>
            <label>If Operation is Fetch RD</label>
        </rules>
        <rules>
