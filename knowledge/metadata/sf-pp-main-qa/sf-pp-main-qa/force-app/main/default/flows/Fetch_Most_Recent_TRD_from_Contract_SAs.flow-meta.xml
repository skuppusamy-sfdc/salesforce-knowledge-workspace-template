                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Contract_with_Approved_NPPA_Tier</targetReference>
            </connector>
            <label>If Operation is Update Contract</label>
        </rules>
    </decisions>
    <description>PR1050558-2235 : Used to fetch most recent TRD from all the SA via HPF Linked to their PNCs</description>
