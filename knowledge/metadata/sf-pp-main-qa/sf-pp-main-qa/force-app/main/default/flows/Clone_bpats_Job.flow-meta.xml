        <name>cloneRecordPlatformEvent</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Clone_Record__e</objectType>
    </variables>
    <variables>
        <name>jobList_var</name>
        <dataType>SObject</dataType>
        <isCollection>true</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>bpats__Job__c</objectType>
    </variables>
    <variables>
        <name>jobObj_var</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>bpats__Job__c</objectType>
    </variables>
    <variables>
        <name>REmail</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <value>
            <stringValue>nbedmutha@salesforce.com</stringValue>
        </value>
    </variables>
    <variables>
