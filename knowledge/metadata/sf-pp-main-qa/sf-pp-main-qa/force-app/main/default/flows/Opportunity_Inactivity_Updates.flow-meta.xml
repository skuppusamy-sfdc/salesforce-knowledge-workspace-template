<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Prospecting_and_Qualify_and_Discover_Needs</name>
        <label>Stage Decision</label>
        <locationX>446</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>Other</defaultConnectorLabel>
        <rules>
            <name>Stage_1_2</name>
            <conditionLogic>(1 OR 2) AND 3</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Prospecting</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Qualify and Discover Needs</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsOpportunityInactive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Close_Record</targetReference>
            </connector>
            <label>Stage 1 &amp; 2</label>
        </rules>
        <rules>
            <name>Stage_3</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Build Sales Strategy</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsOpportunityInactive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Close_Record_2</targetReference>
            </connector>
            <label>Stage 3</label>
        </rules>
        <rules>
            <name>Stage_4</name>
            <conditionLogic>(1 OR 2 OR 3) And 4</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Develop Sponsorship</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Validate Solution</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Negotiate Contract &amp; Close</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>IsOpportunityInactive</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Close_Record_3</targetReference>
            </connector>
            <label>Stage 4+</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>InactivtyThreshold</name>
        <dataType>Number</dataType>
        <expression>CASE(
    $Record.StageName,
    &quot;Qualify and Discover Needs&quot;, 180,
    &quot;Build Sales Strategy&quot;, 150,
    &quot;Prospecting&quot;, 180,
    90 )</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>IsOpportunityInactive</name>
        <dataType>Boolean</dataType>
        <expression>(TODAY() - {!$Record.LastActivityDate}) &gt;= {!InactivtyThreshold}</expression>
    </formulas>
    <interviewLabel>Opportunity Inactivity Updates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opportunity Inactivity Updates</label>
    <processMetadataValues>
        <name>BuilderType</name>
