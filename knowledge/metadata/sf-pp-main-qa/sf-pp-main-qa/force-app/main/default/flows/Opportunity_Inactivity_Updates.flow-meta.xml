        <inputAssignments>
            <field>StageName</field>
            <value>
                <stringValue>Closed - No Change</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
        <name>Close_Record_2</name>
        <label>Close Record 2</label>
        <locationX>314</locationX>
        <locationY>360</locationY>
        <inputAssignments>
            <field>StageName</field>
            <value>
                <stringValue>Closed - No Change</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <recordUpdates>
