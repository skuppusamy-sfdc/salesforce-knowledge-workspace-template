<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <decisions>
        <name>Check_For_IC_Employement_Type</name>
        <label>Check For IC Employement Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_IC</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Contract__r.Employment_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Independent Contractor</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Tax_Information</targetReference>
            </connector>
            <label>Is IC</label>
        </rules>
    </decisions>
    <decisions>
        <name>Tax_Type_Decision</name>
        <label>Tax Type Decision</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Case_Integration_Flag_to_Failed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Type_Individual</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Tax_Information.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Individual</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PE_for_Individual</targetReference>
            </connector>
            <label>Type Individual</label>
        </rules>
        <rules>
            <name>Type_Business_Entity</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Tax_Information.Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Business Entity</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>PEforBusinessEntity</targetReference>
            </connector>
            <label>Type Business Entity</label>
        </rules>
    </decisions>
    <description>This flow will send platform events to mule for IC contract type post 120 days of Case Closedate.</description>
    <environments>Default</environments>
    <formulas>
        <name>BusinesEntityNameforIndiviualType</name>
        <dataType>String</dataType>
        <expression>{!$Record.Contact.FirstName} + &quot; &quot; +{!$Record.Contact.LastName} + &quot; &quot;+TEXT($Record.Contact.Professional_Title__c)</expression>
    </formulas>
    <formulas>
        <name>GlobalProviderIdText</name>
        <dataType>String</dataType>
        <expression>{!$Record.Contact.Global_Provider_ID__c}</expression>
    </formulas>
    <formulas>
        <name>SSNEncrypted</name>
        <dataType>String</dataType>
        <expression>&apos;*****&apos;+{!$Record.Contact.SSN_Last_4_Digit__c}</expression>
    </formulas>
    <formulas>
        <name>Today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>Case Closure Workday Intimation Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Case Closure Workday Intimation Flow</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordCreates>
        <name>Create_Task_To_Notify_Failure</name>
        <label>Create Task To Notify Failure</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>ActivityDate</field>
            <value>
                <elementReference>$Flow.CurrentDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Description</field>
            <value>
                <stringValue>Issue with CTI Record</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>$Record.OwnerId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RecordTypeId</field>
            <value>
                <elementReference>Get_Default_Task_Recordtype_Id.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Subject</field>
            <value>
                <stringValue>Integration Failed</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>WhatId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <object>Task</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordCreates>
        <name>PE_for_Individual</name>
        <label>PE for Individual</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Business_Entity_Name__c</field>
            <value>
                <elementReference>BusinesEntityNameforIndiviualType</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Case_Id__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Global_Provider_Id__c</field>
            <value>
                <elementReference>GlobalProviderIdText</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Reason_Description__c</field>
            <value>
                <elementReference>$Record.Description</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Tax_Id__c</field>
            <value>
                <elementReference>SSNEncrypted</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Tax_Type__c</field>
            <value>
                <stringValue>Individual</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Type__c</field>
            <value>
                <stringValue>Independent Contractor</stringValue>
            </value>
        </inputAssignments>
        <object>Clinician_Offboarding_Request__e</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordCreates>
        <name>PEforBusinessEntity</name>
        <label>PE for Business Entity</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Business_Entity_Name__c</field>
            <value>
                <elementReference>Get_Tax_Information.Corporation_Name__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Case_Id__c</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Global_Provider_Id__c</field>
            <value>
                <elementReference>GlobalProviderIdText</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Reason_Description__c</field>
            <value>
                <elementReference>$Record.Description</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Tax_Id__c</field>
            <value>
                <elementReference>Get_Tax_Information.Corporate_Tax_ID__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Tax_Type__c</field>
            <value>
                <stringValue>Business Entity</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Type__c</field>
            <value>
                <stringValue>Independent Contractor</stringValue>
            </value>
        </inputAssignments>
        <object>Clinician_Offboarding_Request__e</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordCreates>
    <recordLookups>
        <name>Get_Default_Task_Recordtype_Id</name>
        <label>Get Default Task Recordtype Id</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Create_Task_To_Notify_Failure</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>SobjectType</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Task</stringValue>
            </value>
        </filters>
        <filters>
            <field>DeveloperName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Default</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>RecordType</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Tax_Information</name>
        <label>Get Tax Information</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Tax_Type_Decision</targetReference>
        </connector>
        <filterLogic>1 AND 5 AND 2 AND (3 OR 4)</filterLogic>
        <filters>
            <field>Clinician__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.ContactId</elementReference>
            </value>
        </filters>
        <filters>
            <field>Effective_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>Today</elementReference>
            </value>
        </filters>
        <filters>
            <field>Expiration_Date__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>Today</elementReference>
            </value>
        </filters>
        <filters>
            <field>Expiration_Date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Executed</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Corporation_and_Tax_Information__c</object>
        <sortField>Effective_Date__c</sortField>
        <sortOrder>Desc</sortOrder>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Case_Integration_Flag_to_Failed</name>
        <label>Update Case Integration Flag to Failed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Default_Task_Recordtype_Id</targetReference>
        </connector>
        <inputAssignments>
            <field>Latest_Integration_Status__c</field>
            <value>
                <stringValue>Failed</stringValue>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_For_IC_Employement_Type</targetReference>
        </connector>
        <filterLogic>1 AND 2 AND 3 AND 4 AND (5 OR 6)</filterLogic>
        <filters>
            <field>Type</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>SCP</stringValue>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Closed</stringValue>
            </value>
        </filters>
        <filters>
            <field>Closed_Reason__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Complete</stringValue>
            </value>
        </filters>
        <filters>
            <field>RecordTypeName__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Clinician_Offboarding</stringValue>
            </value>
        </filters>
        <filters>
            <field>PE_Workday_Criteria_Met__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Latest_Integration_Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Failed</stringValue>
            </value>
        </filters>
        <object>Case</object>
        <schedule>
            <dayOfMonthToRun>0</dayOfMonthToRun>
            <frequency>Daily</frequency>
            <frequencyNumber>0</frequencyNumber>
            <startDate>2025-12-22</startDate>
            <startTime>08:02:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
</Flow>
