    <formulas>
        <name>ExistingRateDecreased</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.Cloned_From__c} != NULL &amp;&amp; NOT({!$Record.Is_Deleted__c}), IF({!$Record.Rate__c} &lt; VALUE({!$Record.Previous_Rate__c}), true, false), false)</expression>
    </formulas>
    <formulas>
        <name>ExistingRateIncreased</name>
        <dataType>Boolean</dataType>
        <expression>IF({!$Record.Cloned_From__c} != NULL &amp;&amp; NOT({!$Record.IsDeleted}), IF({!$Record.Rate__c} &gt; VALUE({!$Record.Previous_Rate__c}), true, false), false)</expression>
    </formulas>
    <formulas>
        <name>ExistingShiftTypeAdded</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISBLANK({!$Record.Cloned_From__c}) &amp;&amp; NOT(ISBLANK({!$Record.Shift__c}))  &amp;&amp; NOT({!$Record.Is_Deleted__c}), IF({!$Record.Shift__r.Existing_Shift_Type_Added__c}, true, false), false)</expression>
    </formulas>
    <formulas>
        <name>IsMixedBagShiftRate</name>
        <dataType>Boolean</dataType>
        <expression>{!MinRate}&lt;&gt;{!MaxRate}</expression>
    </formulas>
    <formulas>
        <name>IsOverrate</name>
        <dataType>Boolean</dataType>
        <expression>NOT({!$Record.Is_Deleted__c}) &amp;&amp; ({!$Record.Rate__c} &gt; VALUE({!$Record.Facility_Level_Rate__c}))</expression>
    </formulas>
    <formulas>
        <name>NewlyAdded</name>
        <dataType>Boolean</dataType>
        <expression>ISBLANK({!$Record.Cloned_From__c}) &amp;&amp; NOT({!$Record.Is_Deleted__c})</expression>
    </formulas>
    <formulas>
        <name>NewShiftBonusTypeAdded</name>
        <dataType>Boolean</dataType>
        <expression>IF(ISBLANK({!$Record.Cloned_From__c}) &amp;&amp; NOT(ISBLANK({!$Record.Shift__c}))  &amp;&amp; NOT({!$Record.Is_Deleted__c}), IF({!$Record.Shift__r.New_Shift_Bonus_Type_Added__c}, true, false), false)</expression>
    </formulas>
    <formulas>
        <name>NewShiftTypeAdded</name>
