    <decisions>
        <description>Identifies what the team member role is</description>
        <name>What_is_the_Team_Member_Role</name>
        <label>What is the Team Member Role</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Assign_specific_Account_Team_Members</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>VPO</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Assign_specific_Account_Team_Members.TeamMemberRole</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>VP Operations</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_SFO_User_Id</targetReference>
            </connector>
            <label>VPO</label>
        </rules>
        <rules>
            <name>RMO</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Assign_specific_Account_Team_Members.TeamMemberRole</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Regional Medical Officer</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>RMO2</targetReference>
            </connector>
            <label>RMO</label>
        </rules>
        <rules>
            <name>Recruiter_Primary</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Assign_specific_Account_Team_Members.TeamMemberRole</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Recruiter-Primary</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Primary_Recruiter</targetReference>
            </connector>
            <label>Recruiter-Primary</label>
        </rules>
    </decisions>
    <description>Assigns Account Team members to fields on the job record.</description>
    <environments>Default</environments>
    <interviewLabel>Account Team Member to Job {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Account Team Member to Job</label>
    <loops>
        <description>Loops through the variable and assigns the related account team member to the fields on the job</description>
        <name>Assign_specific_Account_Team_Members</name>
        <label>Assign specific Account Team Members</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>ListOfAccountTeamMembers</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>What_is_the_Team_Member_Role</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Update_Team_Members_on_Job</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <description>Gets the Account Team Members of the Facility</description>
        <name>Get_Account_Team_Members</name>
        <label>Get Account Team Members</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Assign_specific_Account_Team_Members</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>AccountId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Facility_Name__r.Id</elementReference>
            </value>
        </filters>
        <object>AccountTeamMember</object>
        <outputReference>ListOfAccountTeamMembers</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>TeamMemberRole</queriedFields>
        <queriedFields>UserId</queriedFields>
        <queriedFields>AccountId</queriedFields>
    </recordLookups>
    <recordUpdates>
        <description>Updates the related team members on the job.</description>
        <name>Update_Team_Members_on_Job</name>
        <label>Update Team Members on Job</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>RMO2__c</field>
            <value>
                <elementReference>RMOID</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Recruiter__c</field>
            <value>
                <elementReference>RecruiterID</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>VPO2__c</field>
            <value>
                <elementReference>VPOID</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Account_Team_Members</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Facility_Name__c</field>
            <operator>NotEqualTo</operator>
        </filters>
        <object>bpats__Job__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
