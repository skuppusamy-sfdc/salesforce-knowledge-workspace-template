    </assignments>
    <assignments>
        <description>Sets the SFO User Id</description>
        <name>Set_SFO_User_Id</name>
        <label>Set VPO User Id</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>VPOID</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Assign_specific_Account_Team_Members.UserId</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_specific_Account_Team_Members</targetReference>
        </connector>
