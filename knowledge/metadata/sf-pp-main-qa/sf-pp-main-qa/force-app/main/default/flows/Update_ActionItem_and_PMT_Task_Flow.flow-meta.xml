    <decisions>
        <name>Action_Plan_Item_Check</name>
        <label>Action Plan Item Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Has_Action_Plan_Item</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Check_for_Action_Plan_Item</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Updating_the_Action_Plan</targetReference>
            </connector>
            <label>Has Action Plan Item</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_3</name>
        <label>Decision 3</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Segregate_Open_and_Completed</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Open_Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Segregate_Open_and_Completed.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Open</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Open_Task_Assignment</targetReference>
            </connector>
            <label>Open Status</label>
        </rules>
        <rules>
            <name>Completed_Status</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Segregate_Open_and_Completed.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completed</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Completed_Task_Assignment</targetReference>
            </connector>
            <label>Completed Status</label>
        </rules>
    </decisions>
    <decisions>
        <name>Item_Type_Check</name>
        <label>Item Type Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>fetch_the_related_Task_Records</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_Task</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fetch_the_related_Task_Records.ItemEntityType</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Task</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Extract_Task_Ids</targetReference>
            </connector>
            <label>Is Task</label>
        </rules>
    </decisions>
    <decisions>
        <name>PMT_Task_Check</name>
        <label>PMT Task Check</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PMT_Task_Exist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Related_PMT_Task</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Transform_Values</targetReference>
            </connector>
            <label>PMT Task Exist</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>CaliculateThePercentage</name>
        <dataType>Number</dataType>
        <expression>IF({!Transform_Values.Total_Tasks__c} &gt; 0, 
   ({!Transform_Values.No_of_Completed_Tasks__c} / {!Transform_Values.Total_Tasks__c}) * 100, 
   0)</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Update ActionItem and PMT Task Flow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Update ActionItem and PMT Task Flow</label>
    <loops>
        <name>fetch_the_related_Task_Records</name>
        <label>fetch the related Task Records</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_All_Related_Action_Plan_Items</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Item_Type_Check</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_all_Related_Tasks</targetReference>
        </noMoreValuesConnector>
    </loops>
    <loops>
        <name>Segregate_Open_and_Completed</name>
        <label>Segregate Open and Completed</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>Get_all_Related_Tasks</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Decision_3</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_Related_PMT_Task</targetReference>
        </noMoreValuesConnector>
    </loops>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
