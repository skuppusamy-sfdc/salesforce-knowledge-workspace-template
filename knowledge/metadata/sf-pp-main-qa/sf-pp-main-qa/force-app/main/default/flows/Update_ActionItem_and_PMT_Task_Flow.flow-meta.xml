            <assignToReference>CompletedTasks</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Segregate_Open_and_Completed</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Segregate_Open_and_Completed</targetReference>
        </connector>
    </assignments>
    <assignments>
