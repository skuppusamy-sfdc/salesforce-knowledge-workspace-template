    </formulas>
    <formulas>
        <name>formula_recordLink</name>
        <dataType>String</dataType>
        <expression>LEFT({!$Api.Partner_Server_URL_260}, FIND(&apos;/services&apos;, {!$Api.Partner_Server_URL_260})) &amp; {!Get_Pro_Forma_Model.Id}</expression>
    </formulas>
    <formulas>
        <name>formula_RejectedSubject</name>
        <dataType>String</dataType>
        <expression>{!Get_Pro_Forma_Model.Name} +&apos; is now Rejected.&apos;</expression>
    </formulas>
