    </formulas>
    <formulas>
        <name>formula_OpportunityStatusApproved</name>
        <dataType>String</dataType>
        <expression>IF({!Get_Pro_Forma_Model.Approval_Type__c} = &apos;Submit for Contracting&apos;,&apos;Approved for Contracting&apos;,&apos;Model Confirmed&apos;)</expression>
    </formulas>
    <formulas>
        <name>formula_ProformaStatusApproved</name>
        <dataType>String</dataType>
