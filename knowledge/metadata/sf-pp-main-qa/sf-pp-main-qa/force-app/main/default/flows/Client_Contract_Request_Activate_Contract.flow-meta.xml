        <allowPause>false</allowPause>
        <fields>
            <name>ContractNotEligible</name>
            <fieldText>&lt;p&gt;&lt;strong style=&quot;color: rgb(231, 6, 6); font-size: 14px; background-color: rgb(255, 255, 255);&quot;&gt;This record is not eligible for Activation.&lt;/strong&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
            <styleProperties>
                <verticalAlignment>
                    <stringValue>top</stringValue>
                </verticalAlignment>
                <width>
                    <stringValue>12</stringValue>
                </width>
            </styleProperties>
        </fields>
        <nextOrFinishButtonLabel>Cancel</nextOrFinishButtonLabel>
        <showFooter>true</showFooter>
        <showHeader>true</showHeader>
    </screens>
    <screens>
        <name>PNC_Error_Activate_Master_Contract</name>
        <label>PNC Error Activate Master Contract</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>PNC_Error</name>
