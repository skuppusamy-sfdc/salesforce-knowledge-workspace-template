            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Original_HPF_with_matching_AccountId_and_PractitionerId</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_HPF_fields</targetReference>
            </connector>
            <label>Original HPF Exists</label>
        </rules>
    </decisions>
    <description>HPF Save Sub Flow - PR1050558-4980, PR1050558-5090
Date Validation for Automated Create HPF from Job</description>
    <environments>Default</environments>
    <formulas>
        <name>DueDateTodayPlus1</name>
        <dataType>Date</dataType>
        <expression>TODAY() +1</expression>
    </formulas>
    <formulas>
        <name>EffectiveFromWithOneDayPrior</name>
        <dataType>Date</dataType>
        <expression>{!NewHPF.EffectiveFrom}-1</expression>
    </formulas>
    <formulas>
        <name>NewHPFEffectiveFromSubstract1</name>
        <dataType>Date</dataType>
        <expression>{!NewHPF.EffectiveFrom} - 1</expression>
    </formulas>
    <formulas>
        <name>OriginalHPFEffectiveToPlus1</name>
        <dataType>Date</dataType>
        <expression>{!Get_Original_HPF.EffectiveTo} + 1</expression>
    </formulas>
