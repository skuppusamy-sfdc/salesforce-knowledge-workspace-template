    <decisions>
        <name>Check_Effective_From_and_To</name>
        <label>Check Effective From and To</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <isGoTo>true</isGoTo>
            <targetReference>Get_Original_HPF_with_matching_AccountId_and_PractitionerId</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Original_To_is_prior_to_New_From</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>NewHPF.EffectiveFrom</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>Get_Original_HPF.EffectiveTo</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Original_HPF</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Original_HPF.EffectiveTo</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_New_Effective_From</targetReference>
            </connector>
            <label>EFrom : Original To is prior to New From</label>
        </rules>
        <rules>
            <name>Original_To_has_a_gap_between_New_From</name>
            <conditionLogic>(1 OR 3) AND 2</conditionLogic>
            <conditions>
                <leftValueReference>NewHPF.EffectiveFrom</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>Get_Original_HPF.EffectiveTo</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Original_HPF</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Original_HPF.EffectiveTo</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Existing_HPF_Record</targetReference>
            </connector>
            <label>Original To has a gap between New From</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Facility_Title_Changes</name>
        <label>Check Facility Title Changes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Is_changed_from_Employee_to_IC_or_vice_versa</name>
            <conditionLogic>(1 AND 2) OR (3 AND 4)</conditionLogic>
            <conditions>
                <leftValueReference>NewHPF.Facility_Title__r.Code_Set_Sub_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Employee</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Original_HPF_with_matching_AccountId_and_PractitionerId.Facility_Title__r.Code_Set_Sub_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Independent Contractor</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Original_HPF_with_matching_AccountId_and_PractitionerId.Facility_Title__r.Code_Set_Sub_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Employee</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>NewHPF.Facility_Title__r.Code_Set_Sub_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Independent Contractor</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_when_Facility_Title_changed</targetReference>
            </connector>
            <label>Is changed from Employee to IC or vice versa</label>
        </rules>
    </decisions>
    <decisions>
